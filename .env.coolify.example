# ─── Coolify Production Environment Variables ───
# Copy into Coolify's Environment Variables tab, set values, and deploy.

# Database (use Coolify-managed MongoDB or external connection string)
DATABASE_URL=mongodb://mongo:27017/taskly

# Payload — 32+ char random string (generate once, never change)
PAYLOAD_SECRET=CHANGE_ME_to_a_long_random_string_at_least_32_characters

# Public URLs
NEXT_PUBLIC_SERVER_URL=https://api-task.algonest.tech
FRONTEND_URL=https://task.algonest.tech

# Cookie domain (leading dot = shared across *.algonest.tech subdomains)
AUTH_COOKIE_DOMAIN=.algonest.tech

# Initial super-admin (auto-created on first boot if not already present)
ADMIN_EMAIL=admin@erticaz.com
ADMIN_PASSWORD=CHANGE_ME
ADMIN_NAME=Admin

# Optional: error tracking
SENTRY_DSN=
NUXT_PUBLIC_SENTRY_DSN=

# Optional: Web Push (VAPID keys) — generate with `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@erticaz.com
