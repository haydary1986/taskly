# Database
DATABASE_URL=mongodb://127.0.0.1:27017/taskly

# Payload Secret
PAYLOAD_SECRET=your_secret_key_here

# URLs
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# Push Notifications (VAPID)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:admin@your-domain.com

# System Logging
LOG_LEVEL=debug

# --- Sentry Error Tracking ---
# DSN for the server and client
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Organization and Project names in Sentry (for uploading source maps)
SENTRY_ORG=
SENTRY_PROJECT=

# Sentry API token (create this in Sentry account settings)
SENTRY_AUTH_TOKEN=
