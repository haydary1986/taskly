# API URL
NUXT_PUBLIC_API_BASE=http://localhost:3000

# --- Sentry Error Tracking ---
# The DSN provided by Sentry for your web project
NUXT_PUBLIC_SENTRY_DSN=

# Organization and Project names in Sentry (for uploading source maps)
SENTRY_ORG=
SENTRY_PROJECT=

# Sentry API token (create this in Sentry account settings)
SENTRY_AUTH_TOKEN=
