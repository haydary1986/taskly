{
  "name": "taskly",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "dev:api": "pnpm --filter @taskly/api dev",
    "dev:web": "pnpm --filter @taskly/web dev",
    "build:api": "pnpm --filter @taskly/api build",
    "build:web": "pnpm --filter @taskly/web build"
  },
  "devDependencies": {
    "turbo": "^2.8.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "@parcel/watcher",
      "vue-demi"
    ],
    "overrides": {
      "minimatch@>=3.0.0 <3.1.4": "3.1.4",
      "minimatch@>=4.0.0 <4.2.1": "4.2.1",
      "minimatch@>=5.0.0 <5.1.8": "5.1.8",
      "minimatch@>=6.0.0 <6.2.3": "6.2.3",
      "minimatch@>=7.0.0 <7.4.5": "7.4.5",
      "minimatch@>=8.0.0 <8.0.5": "8.0.5",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "minimatch@>=10.0.0 <10.2.3": "10.2.3",
      "cross-spawn@>=7.0.0 <7.0.6": ">=7.0.6",
      "next": ">=15.5.10",
      "koa": ">=2.16.4",
      "serialize-javascript": ">=7.0.3",
      "ajv": ">=8.18.0",
      "dompurify": ">=3.3.2",
      "svgo": ">=4.0.1",
      "immutable": ">=4.3.8",
      "tar": ">=7.5.10"
    }
  },
  "packageManager": "pnpm@9.15.4",
  "dependencies": {
    "ofetch": "^1"
  }
}