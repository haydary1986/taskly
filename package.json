{
  "name": "taskly",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "dev:api": "pnpm --filter @taskly/api dev",
    "dev:web": "pnpm --filter @taskly/web dev",
    "build:api": "pnpm --filter @taskly/api build",
    "build:web": "pnpm --filter @taskly/web build"
  },
  "devDependencies": {
    "turbo": "^2.8.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "@parcel/watcher",
      "vue-demi"
    ],
    "overrides": {
      "minimatch@>=5.0.0 <5.1.8": ">=5.1.8",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "cross-spawn@>=7.0.0 <7.0.6": ">=7.0.6"
    }
  },
  "packageManager": "pnpm@9.15.4"
}